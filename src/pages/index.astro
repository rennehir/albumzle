---
import DefaultLayout from "../layouts/Default.astro";
import Album from "../components/Album.astro";
import { getRandomAlbums } from "../services/albums.ts";

const albums = getRandomAlbums(5);
---

<DefaultLayout title="Albumzle">
  {
    albums.map((album) => (
      <Album
        artist={album.artist}
        album={album.name}
        releaseDate={album.releaseDate}
      />
    ))
  }
</DefaultLayout>
