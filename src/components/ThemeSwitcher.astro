---
import { themeGroups } from "../styles/themes";
---

<div class="dropdown dropdown-end">
  <label tabindex="0" class="btn btn-ghost btn-sm"> 🎨 Theme </label>

  <div
    tabindex="0"
    class="dropdown-content z-[1] p-3 shadow bg-base-100 rounded-box w-64 max-h-96 overflow-y-auto"
  >
    {
      Object.entries(themeGroups).map(([group, themes]) => (
        <div class="mb-3">
          <div class="text-xs font-bold opacity-60 mb-1">{group}</div>

          <div class="flex flex-col gap-1">
            {themes.map((theme) => (
              <button
                class="theme-option flex items-center gap-2 p-2 rounded hover:bg-base-200 text-left data-[active=true]:bg-primary data-[active=true]:text-primary-content"
                data-theme={theme.name}
              >
                {/* 🎨 preview dot */}
                <span class={`w-3 h-3 rounded-full ${theme.preview}`} />

                <span>{theme.label}</span>
              </button>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  const root = document.documentElement;

  const saved =
    localStorage.getItem("theme") ||
    (window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light");

  root.setAttribute("data-theme", saved);
  document.querySelectorAll<HTMLElement>(".theme-option").forEach((btn) => {
    btn.addEventListener("click", () => {
      const theme = btn.dataset.theme;
      if (!theme) return;

      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
    });
  });
</script>
