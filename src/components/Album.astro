---
interface Props {
  artist: string;
  album: string;
  releaseDate: string;
}

const { artist, album, releaseDate } = Astro.props;
---

<article>
  <h2>{album}</h2>
  <h3>{artist}</h3>
  <p>{releaseDate}</p>
</article>

<style>
  article {
    border: 1px solid #f1f1f1;
    padding: 1rem;
    margin: 1rem;
  }
</style>
